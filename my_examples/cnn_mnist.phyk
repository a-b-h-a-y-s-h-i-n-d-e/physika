# how to calculate shapes of every block of CNN

# CONV -> H x W 
# kernel -> Kh x kw
# lets calculate output of this, in forward code it is conv1
# input - 28x28
# out_height = [ (H - Kh + 2P) / S ] + 1
# P = padding
# S = stride 
# P = 0
# S = 1 (no stride == 1)
# (28 - 3 + 2*0) / 1 + 1
# 26
# conv1 = 26x26


# Maxpool output size
# out_height = [H - Ph] / S + 1
# out_width = [W - Pw] / S + 1
# conv1 output = 26x26
# pool = 2x2
# stride = 2
# 26 - 2 / 2 + 1 = 3
# output = 13x13


# neural network
# 13x13 = 169 inputs

# why w has shape of [10, 169]
# neural network takes 169 as inputs
# and it outputs 10

# input -> 8x8
# kernel -> 3x3
# conv output -> 6x6


