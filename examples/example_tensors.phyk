#T

# Linear map: T^־±_־² applied to vector v^־²
T: R[+3,-3] = [[2.0, 0.0, 0.0], # Add support for ten
               [0.0, 3.0, 0.0],
               [0.0, 0.0, 4.0]]

v: R[+3, +1] = [[1.0], [2.0], [3.0]]

# Contraction: T^־±_־² v^־² = w^־±
w: R[+3, +1] = T @ v
w

